{
  "cleanUrls": true,
  "trailingSlash": false,
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-XSS-Protection",
          "value": "1; mode=block"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/deploy-gate",
      "destination": "/deploy-gate.html"
    },
    {
      "source": "/architecture",
      "destination": "/architecture.html"
    },
    {
      "source": "/receipt-model",
      "destination": "/receipt-model.html"
    },
    {
      "source": "/request-access",
      "destination": "/request-access.html"
    },
    {
      "source": "/install",
      "destination": "/install.html"
    },
    {
      "source": "/challenge",
      "destination": "/challenge.html"
    }
  ]
}
